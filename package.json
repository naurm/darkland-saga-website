    "@prisma/client": "^5.22.0",
    "next-auth": "^5.0.0-beta.31",
    "@auth/prisma-adapter": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "tailwindcss": "^3.4.0",
    "postcss": "^8",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35"
  }
